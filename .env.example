PORT=3001
HOST=0.0.0.0

# نافذة مواعيد الحجز (اليوم + الأيام التالية)
BOOKING_WINDOW_DAYS=5

# ─── الذكاء الاصطناعي (افتراضي: OpenRouter + Gemma 4 31B) ───
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=google/gemma-4-31b-it
# نسخة مجانية (اختياري): google/gemma-4-31b-it:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# بديل محلي
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5

# بديل Google
# GEMINI_API_KEY=

# ─── عنوان API للموبايل ───
# public/app-config.json أو npm run config:host أو ⚙ في التطبيق
# VITE_API_BASE_URL=
